# ─── Database ───────────────────────────────────────────────────────────────
DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DB_SSL=true

# ─── AI (OpenRouter) ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
AI_MODEL=anthropic/claude-3.5-sonnet

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-github-username
GITHUB_ORG=                          # optional: push to an org instead of personal account

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Docker sandbox ──────────────────────────────────────────────────────────
SANDBOX_TIMEOUT_MS=60000             # max execution time per sandbox run
SANDBOX_MAX_RETRIES=3                # debugger retry attempts
