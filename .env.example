# ─── Copy this file to .env and fill in real values ─────────────────────────

# Supabase PostgreSQL connection string
DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres
DB_SSL=true

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
# Model to use – any OpenRouter model ID works, e.g.:
#   anthropic/claude-3.5-sonnet  (default)
#   openai/gpt-4o
#   google/gemini-pro-1.5
AI_MODEL=anthropic/claude-3.5-sonnet

# GitHub OAuth App (https://github.com/settings/developers → OAuth Apps)
# Callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# JWT signing secret – run: openssl rand -hex 32
JWT_SECRET=your-jwt-secret

# Token encryption key (32-byte hex) – run: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-encryption-key

# GitHub personal access token (fallback/dev only – not needed when using OAuth)
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-username
GITHUB_ORG=                      # optional

# Redis (leave as-is when using docker-compose)
REDIS_URL=redis://localhost:6379

# Frontend URLs (used by docker-compose build args)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
FRONTEND_URL=http://localhost:3000

# Sandbox tuning
SANDBOX_TIMEOUT_MS=60000
SANDBOX_MAX_RETRIES=3
