# Sandbox base image for running generated projects.
# The dockerRunner builds a project-specific image FROM this base,
# so common tooling is already cached.

FROM node:20-alpine

WORKDIR /app

# Install common runtimes and tools available inside sandboxes
RUN apk add --no-cache python3 py3-pip curl bash

# Pre-cache common npm packages to speed up sandbox builds
RUN npm install -g typescript ts-node nodemon

USER node

CMD ["node", "index.js"]
